# Get free key at https://aistudio.google.com
GEMINI_API_KEY=

# Get at https://resend.com (free tier: 3000 emails/month)
RESEND_API_KEY=

# Where to send alerts
RECIPIENT_EMAIL=your@email.com

# Comma-separated keywords to watch (lowercase). Used for RSS filtering + Google News queries.
# In GitHub Actions, set this as a repository variable (not secret) at Settings → Variables → Actions.
WATCH_KEYWORDS=binance,bybit,youhodler

# ── Telegram (optional) ──────────
# Get bot token from @BotFather, chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
